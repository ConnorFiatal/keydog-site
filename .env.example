# Server
PORT=3100
BASE_URL=https://keydog.app

# Stripe
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_CAMPUS=price_...

# Coolify
COOLIFY_URL=https://coolify.yourserver.com
COOLIFY_TOKEN=your-coolify-api-token
COOLIFY_SERVER_UUID=your-server-uuid
COOLIFY_PROJECT_UUID=your-project-uuid
COOLIFY_ENVIRONMENT=production

# KeyDog app repo (deployed per customer)
KEYDOG_GIT_REPO=https://github.com/yourorg/keydog
KEYDOG_GIT_BRANCH=main

# n8n webhook base URL (set all three paths in n8n)
N8N_WEBHOOK_URL=https://n8n.yourserver.com/webhook
