<!DOCTYPE html>
<html lang="en">
<head><%- include('partials/head') %></head>
<body>

<%- include('partials/nav') %>

<!-- ── Hero ──────────────────────────────────────────────────────── -->
<section class="hero">
<div class="hero-content">
  <div class="hero-inner">
    <div class="hero-badge">For facilities, education &amp; institutional campuses</div>
    <h1 class="hero-headline">
      Every key.<br>
      Every door.<br>
      <em>Under control.</em>
    </h1>
    <p class="hero-sub">
      Manage physical keys, fob profiles, door records, and audit trails across every building,
      site, and campus — from one organized platform.
    </p>
    <div class="hero-cta">
      <a href="/signup?plan=campus" class="btn btn-gold btn-lg">Start free trial</a>
      <a href="#demo" class="btn btn-outline-light btn-lg">See a demo</a>
    </div>
    <p class="hero-note">14 Day Free Trial &nbsp;·&nbsp; Setup in under 24 hours</p>
  </div>

  <div class="hero-visual" aria-hidden="true">
    <div class="mock-browser">
      <div class="mock-browser-bar">
        <span class="mock-dot"></span><span class="mock-dot"></span><span class="mock-dot"></span>
