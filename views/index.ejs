          <div class="mock-nav-item"></div>
          <div class="mock-nav-item"></div>
          <div class="mock-nav-spacer"></div>
          <div class="mock-nav-item short"></div>
        </div>
        <div class="mock-content">
          <div class="mock-page-title"></div>
          <div class="mock-stat-row">
            <div class="mock-stat">
              <div class="mock-stat-num"></div>
              <div class="mock-stat-label"></div>
            </div>
            <div class="mock-stat">
              <div class="mock-stat-num"></div>
              <div class="mock-stat-label"></div>
            </div>
            <div class="mock-stat">
              <div class="mock-stat-num"></div>
              <div class="mock-stat-label"></div>
            </div>
            <div class="mock-stat">
              <div class="mock-stat-num"></div>
              <div class="mock-stat-label"></div>
            </div>
          </div>
          <div class="mock-table">
            <div class="mock-table-head"></div>
            <div class="mock-table-row"></div>
