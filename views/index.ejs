            <div class="mock-table-row"></div>
            <div class="mock-table-row short"></div>
            <div class="mock-table-row"></div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div><!-- /.hero-content -->
</section>

<!-- ── Trust bar ─────────────────────────────────────────────────── -->
<div class="trust-bar">
  <div class="trust-inner">
    <span class="trust-label">Trusted by facilities teams across education, healthcare, and government</span>
    <div class="trust-stats">
      <div class="trust-stat"><strong>10,000+</strong> keys tracked</div>
      <div class="trust-divider"></div>
      <div class="trust-stat"><strong>500+</strong> door records</div>
      <div class="trust-divider"></div>
      <div class="trust-stat"><strong>100%</strong> audit coverage</div>
    </div>
  </div>
</div>

<!-- ── Features teaser ────────────────────────────────────────── -->
<section class="features-teaser" id="features">
  <div class="section-inner">
    <div class="section-label">Everything you need</div>
    <h2 class="section-title">One platform, every access credential</h2>
    <p class="section-sub">Stop juggling spreadsheets, binders, and paper sign-outs. KeyDog covers the full lifecycle — from key issuance to door audits.</p>

    <div class="feat-teaser-grid">
      <a href="/features#keys" class="feat-teaser-item">
        <div class="feature-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"><path d="M21 2l-2 2m-7.61 7.61a5.5 5.5 0 1 1-7.778 7.778 5.5 5.5 0 0 1 7.777-7.777zm0 0L15.5 7.5m0 0l3 3L22 7l-3-3m-3.5 3.5L19 4"/></svg>
        </div>
        <h3>Physical Key Tracking</h3>
      </a>
      <a href="/features#doors" class="feat-teaser-item">
        <div class="feature-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
        </div>
        <h3>Door Management</h3>
      </a>
      <a href="/features#fobs" class="feat-teaser-item">
        <div class="feature-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"><rect x="2" y="5" width="20" height="14" rx="2"/><path d="M16 10a2 2 0 1 1-4 0 2 2 0 0 1 4 0z"/><path d="M6 10h.01M6 14h12"/></svg>
        </div>
        <h3>Fob Profiles</h3>
      </a>
      <a href="/features#audit" class="feat-teaser-item">
        <div class="feature-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        </div>
        <h3>Audit Trail</h3>
      </a>
      <a href="/features#staff" class="feat-teaser-item">
        <div class="feature-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75"/></svg>
        </div>
        <h3>Staff &amp; Safe Management</h3>
      </a>
      <a href="/features#agreements" class="feat-teaser-item">
        <div class="feature-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>
        </div>
        <h3>Key Agreements &amp; Reports</h3>
      </a>
    </div>

    <div class="feat-teaser-cta">
      <a href="/features" class="btn btn-navy">Explore all features &rarr;</a>
    </div>
  </div>
</section>

<!-- ── Demo screenshot ───────────────────────────────────────────── -->
<section class="demo-section" id="demo">
  <div class="section-inner">
    <div class="demo-layout">
      <div class="demo-copy">
        <div class="section-label">Dashboard</div>
        <h2 class="section-title">Everything at a glance</h2>
        <p>The KeyDog dashboard gives facilities managers a real-time view of active keys, outstanding checkouts, door status, and recent audit activity — all without digging through spreadsheets.</p>
        <ul class="demo-list">
          <li>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
            Live stats for keys, doors, staff, and safes
          </li>
          <li>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
            Overdue key alerts with automatic email reminders
          </li>
          <li>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
            Recent audit log with user and timestamp
          </li>
        </ul>
        <a href="/signup?plan=starter" class="btn btn-navy">Try it free</a>
      </div>
      <div class="demo-image-wrap">
        <div class="demo-placeholder">
          <div class="demo-ph-inner">
            <div class="demo-ph-sidebar">
              <div class="demo-ph-logo"></div>
              <div class="demo-ph-nav"></div>
              <div class="demo-ph-nav"></div>
              <div class="demo-ph-nav active"></div>
              <div class="demo-ph-nav"></div>
              <div class="demo-ph-nav"></div>
            </div>
            <div class="demo-ph-body">
              <div class="demo-ph-heading"></div>
              <div class="demo-ph-cards">
                <div class="demo-ph-card gold"></div>
                <div class="demo-ph-card"></div>
                <div class="demo-ph-card"></div>
                <div class="demo-ph-card"></div>
              </div>
              <div class="demo-ph-rows">
                <div class="demo-ph-row"></div>
                <div class="demo-ph-row short"></div>
                <div class="demo-ph-row"></div>
                <div class="demo-ph-row med"></div>
              </div>
            </div>
          </div>
          <div class="demo-ph-label">Dashboard preview</div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ── Second feature spotlight ──────────────────────────────────── -->
<section class="demo-section demo-section-alt">
  <div class="section-inner">
    <div class="demo-layout demo-layout-reverse">
      <div class="demo-image-wrap">
        <div class="demo-placeholder demo-placeholder-alt">
          <div class="demo-ph-inner">
            <div class="demo-ph-sidebar">
              <div class="demo-ph-logo"></div>
              <div class="demo-ph-nav"></div>
              <div class="demo-ph-nav active"></div>
              <div class="demo-ph-nav"></div>
              <div class="demo-ph-nav"></div>
              <div class="demo-ph-nav"></div>
            </div>
            <div class="demo-ph-body">
              <div class="demo-ph-heading"></div>
              <div class="demo-ph-form-row"></div>
              <div class="demo-ph-form-row short"></div>
              <div class="demo-ph-form-row"></div>
              <div class="demo-ph-rows mt">
                <div class="demo-ph-row"></div>
                <div class="demo-ph-row short"></div>
                <div class="demo-ph-row"></div>
              </div>
            </div>
          </div>
          <div class="demo-ph-label">Floor plan &amp; keys view</div>
        </div>
      </div>
      <div class="demo-copy">
        <div class="section-label">Floor Plans</div>
        <h2 class="section-title">Map keys to spaces visually</h2>
        <p>Upload floor plans and link every key and door to a location. Your team can find the right key without knowing building codes or reference numbers.</p>
        <ul class="demo-list">
          <li>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
            Upload building PDFs or images
          </li>
          <li>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
            Pin keys and doors to floor plan locations
          </li>
          <li>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
            Click any pin for full key or door details
          </li>
        </ul>
        <a href="/signup?plan=campus" class="btn btn-navy">Get Campus plan</a>
      </div>
    </div>
  </div>
</section>

<!-- ── How it works ──────────────────────────────────────────────── -->
<section class="hiw" id="how-it-works">
  <div class="section-inner">
    <div class="section-label">Simple by design</div>
    <h2 class="section-title">Up and running in minutes</h2>

    <div class="hiw-steps">
      <div class="hiw-step">
        <div class="hiw-num">01</div>
        <h3>Choose your plan</h3>
        <p>Pick Starter for a single site or Campus for multi-building teams. We handle setup and send your login details by email.</p>
      </div>
      <div class="hiw-connector" aria-hidden="true"></div>
      <div class="hiw-step">
        <div class="hiw-num">02</div>
        <h3>Import your data</h3>
        <p>Upload a CSV of existing keys, staff, or doors. KeyDog's import wizard maps columns automatically.</p>
      </div>
      <div class="hiw-connector" aria-hidden="true"></div>
      <div class="hiw-step">
        <div class="hiw-num">03</div>
        <h3>Start managing</h3>
        <p>Check out keys, log transactions, generate reports, and never lose track of who has what again.</p>
      </div>
    </div>
  </div>
</section>

<!-- ── Pricing preview ───────────────────────────────────────────── -->
<section class="pricing-preview">
  <div class="section-inner">
    <div class="section-label">Transparent pricing</div>
    <h2 class="section-title">Simple pricing for every scale</h2>

    <div class="pricing-cards">

      <div class="pricing-card">
        <div class="plan-name">Starter</div>
        <div class="plan-price"><span class="price-amount">$49</span><span class="price-period">/mo</span></div>
        <p class="plan-desc">For a single campus just getting organised.</p>
        <ul class="plan-features">
          <li>1 campus building</li>
          <li>Up to 3 admin users</li>
          <li>Key &amp; door tracking</li>
          <li>30-day audit log</li>
          <li>Email notifications</li>
        </ul>
        <a href="/signup?plan=starter" class="btn btn-navy btn-full">Get started</a>
      </div>

      <div class="pricing-card pricing-card-featured">
        <div class="plan-badge">Most popular</div>
        <div class="plan-name">Campus</div>
        <div class="plan-price"><span class="price-amount">$149</span><span class="price-period">/mo</span></div>
        <p class="plan-desc">For multi-building facilities teams.</p>
        <ul class="plan-features">
          <li>Up to 5 campus buildings</li>
          <li>Unlimited admin users</li>
          <li>Everything in Starter</li>
          <li>Floor plan management</li>
          <li>Key agreement workflows</li>
          <li>Ring checkout system</li>
          <li>1-year audit retention</li>
        </ul>
        <a href="/signup?plan=campus" class="btn btn-gold btn-full">Get started</a>
      </div>

      <div class="pricing-card">
        <div class="plan-name">Enterprise</div>
        <div class="plan-price"><span class="price-amount">Custom</span></div>
        <p class="plan-desc">Dedicated instance for large institutions.</p>
        <ul class="plan-features">
          <li>Everything in Campus</li>
          <li>Dedicated deployment</li>
          <li>Custom subdomain</li>
          <li>SSO / SAML</li>
          <li>5-year audit retention</li>
          <li>Uptime SLA</li>
          <li>Dedicated support</li>
        </ul>
        <a href="/contact" class="btn btn-navy btn-full">Contact sales</a>
      </div>

    </div>

    <p class="pricing-note">All plans include a 14-day free trial. No credit card required to start.</p>
  </div>
</section>

<!-- ── Final CTA ─────────────────────────────────────────────────── -->
<section class="cta-section">
  <div class="section-inner cta-inner">
    <h2>Stop losing track of who has what.</h2>
    <p>Facilities teams across education, healthcare, and government use KeyDog to replace spreadsheets and binders with a single source of truth.</p>
    <div class="cta-buttons">
      <a href="/signup?plan=campus" class="btn btn-gold btn-lg">Start free trial</a>
      <a href="/contact" class="btn btn-outline-light btn-lg">Talk to sales</a>
    </div>
  </div>
</section>

<%- include('partials/footer') %>

</body>
</html>
