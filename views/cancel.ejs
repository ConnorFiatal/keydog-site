<!DOCTYPE html>
<html lang="en">
<head><%- include('partials/head') %></head>
<body class="page-minimal">

<%- include('partials/nav') %>

<main class="status-page">
  <div class="status-card">
    <div class="status-icon">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
        <line x1="18" y1="6" x2="6" y2="18"/>
        <line x1="6" y1="6" x2="18" y2="18"/>
      </svg>
    </div>

    <h1>Checkout cancelled</h1>
    <p class="status-lead">No worries — your card hasn't been charged. You can go back and pick a plan whenever you're ready.</p>

    <div class="cancel-options">
      <a href="/pricing" class="btn btn-gold btn-lg">View plans again</a>
      <a href="/contact" class="btn btn-ghost">Talk to sales first</a>
    </div>

    <p class="status-note">
      Have questions before signing up? <a href="/contact">Contact us</a> — we're happy to help.
    </p>
  </div>
</main>

<%- include('partials/footer') %>

</body>
</html>
