<!DOCTYPE html>
<html lang="en">
<head><%- include('partials/head') %></head>
<body class="page-minimal">

<%- include('partials/nav') %>

<main class="checkout-flow">
  <div class="checkout-wrap checkout-wrap-narrow">

    <div class="checkout-card">
      <div class="section-label">Enterprise &amp; Sales</div>
      <h1 class="checkout-title">Talk to the team</h1>
      <p class="checkout-sub">Tell us about your institution and we'll put together a tailored quote.</p>

      <form action="mailto:sales@keydog.app" method="GET" class="checkout-form">
        <div class="form-group">
          <label for="name">Your name</label>
          <input type="text" id="name" name="name" placeholder="Jane Smith" required autocomplete="name">
        </div>
        <div class="form-group">
          <label for="email">Work email</label>
          <input type="email" id="email" name="email" placeholder="jane@university.edu" required autocomplete="email">
        </div>
        <div class="form-group">
          <label for="institution">Institution name</label>
          <input type="text" id="institution" name="institution" placeholder="State University" required>
        </div>
        <div class="form-group">
          <label for="buildings">Number of buildings to manage</label>
          <select id="buildings" name="buildings">
            <option value="">Select a range</option>
            <option>1–5</option>
            <option>6–20</option>
            <option>21–50</option>
            <option>50+</option>
          </select>
        </div>
        <div class="form-group">
          <label for="message">Anything else we should know? <span class="label-optional">(optional)</span></label>
          <textarea id="message" name="message" rows="4" placeholder="e.g. We need SSO, or we're migrating from a legacy system…"></textarea>
        </div>
        <button type="submit" class="btn btn-gold btn-full btn-lg">Send message</button>
      </form>

      <p class="checkout-legal">We'll get back to you within one business day.</p>
    </div>

  </div>
</main>

<%- include('partials/footer') %>

</body>
</html>
