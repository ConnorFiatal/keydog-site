<!DOCTYPE html>
<html lang="en">
<head><%- include('partials/head') %></head>
<body class="page-minimal">

<%- include('partials/nav') %>

<main class="status-page">
  <div class="status-card status-success">
    <div class="status-icon status-icon-success">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="20 6 9 17 4 12"/>
      </svg>
    </div>

    <h1>You're in.</h1>
    <p class="status-lead">
      Your KeyDog instance is being provisioned. You'll receive an email with your login link and first-run instructions within a few minutes.
    </p>

    <div class="status-steps">
      <div class="status-step status-step-done">
        <div class="step-dot"></div>
        <div class="step-body">
          <strong>Payment confirmed</strong>
          <span>Your subscription is active</span>
        </div>
      </div>
      <div class="status-step status-step-active">
        <div class="step-dot"></div>
        <div class="step-body">
          <strong>Instance deploying</strong>
          <span>Spinning up your dedicated KeyDog deployment</span>
        </div>
      </div>
      <div class="status-step">
        <div class="step-dot"></div>
        <div class="step-body">
          <strong>Welcome email</strong>
          <span>Login link and setup guide on the way</span>
        </div>
      </div>
    </div>

    <p class="status-note">
      Questions? Email us at <a href="mailto:support@keydog.app">support@keydog.app</a>
    </p>

    <a href="/" class="btn btn-ghost">Back to homepage</a>
  </div>
</main>

<%- include('partials/footer') %>

</body>
</html>
